# Copy this to .env and fill in your values
# On Hetzner: lives at /var/www/studio/.env (same pattern as Hemingway)

SECRET_KEY=replace-with-a-random-string
APP_PASSWORD=replace-with-your-team-password
DB_PATH=/var/www/studio/data/studio.db

# Hemingway integration (server-to-server auth -- see hemingway_client.py).
# TEAM_PASSWORD should match the same password used to log into
# hemingway.kmgtools.us directly today.
HEMINGWAY_BASE_URL=https://hemingway.kmgtools.us
HEMINGWAY_TEAM_PASSWORD=replace-with-hemingways-team-password

# Degas integration (server-to-server auth -- see degas_client.py, task #7).
# TEAM_PASSWORD should match the same password used to log into
# degas.kmgtools.us directly today.
DEGAS_BASE_URL=https://degas.kmgtools.us
DEGAS_TEAM_PASSWORD=replace-with-degas-team-password

# Server IP -- kept out of DEPLOY.md and every other committed file since
# this repo is public. This is the only place it's written down.
SERVER_IP=replace-with-your-hetzner-ip

# Added in later build steps, not needed for the foundation skeleton:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# POSTIZ_API_KEY=
